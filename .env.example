# Database
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://gospelos:changeme@db:5432/gospelos

# Session secret — must be at least 32 characters, cryptographically random
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-this-with-a-32-plus-character-random-string

# First run: creates initial super_admin account if no users exist
# Remove these after first login to avoid accidental re-creation
INITIAL_ADMIN_EMAIL=admin@yourchurch.org
INITIAL_ADMIN_PASSWORD=changeme-on-first-login

# Notification providers (optional for Phase 1)
# NOTIFICATION_SMS_PROVIDER=twilio
# NOTIFICATION_EMAIL_PROVIDER=brevo

# Twilio (if using SMS)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Brevo (if using email)
# BREVO_API_KEY=

# Node environment
NODE_ENV=production
